{
  "name": "tankclash",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --packages=external --format=esm --outfile=dist/server/index.js",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "match:sim": "tsx scripts/matchSim.ts",
    "screenshot": "tsx scripts/screenshot.ts"
  },
  "dependencies": {
    "@colyseus/schema": "^3.0.0",
    "colyseus": "^0.16.0",
    "colyseus.js": "^0.16.0",
    "express": "^4.21.0",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/three": "^0.180.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "playwright": "^1.49.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
