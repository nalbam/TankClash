# --------------------------------------------
# Server Configuration
# --------------------------------------------

PORT=2567
NODE_ENV=production

# Redis for horizontal scaling (ElastiCache)
REDIS_URL=redis://game-redis.xxxxx.cache.amazonaws.com:6379

# CORS - only allow your domain
ALLOWED_ORIGINS=https://game.example.com,https://game.server.example.com

# --------------------------------------------
# Client Build Configuration
# --------------------------------------------

# Your production server address
SERVER_URL=game.server.example.com
