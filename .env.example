# --------------------------------------------
# Server Configuration (runtime)
# --------------------------------------------

# Server port (read by server/index.ts; also set in the Dockerfile)
PORT=2567

# Node environment (development | production) — set to production in the Docker image
NODE_ENV="development"

# Comma-separated allowlist of origins permitted in production (WebSocket + /api CORS).
# e.g. https://nalbam.github.io,https://tankclash.game.example.com
ALLOWED_ORIGINS=

# --------------------------------------------
# Client Configuration (build-time)
# --------------------------------------------

# Server address the client connects to.
# Used during the Vite build (vite.config.ts injects it as __SERVER_URL__).
# Example: game.example.com:2567 or game.example.com (port 443)
SERVER_URL="localhost:2567"
